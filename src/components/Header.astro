---
import HeaderLink from './HeaderLink.astro';

const currentPath = Astro.url.pathname;
const isEnglish = currentPath.startsWith('/en') || currentPath.includes('/en/');

const homeLink = isEnglish ? '/en/' : '/';
const blogLink = '/blog/';
const aboutLink = '/about/';
const langToggleLink = isEnglish ? '/' : '/en/';
const langToggleText = isEnglish ? '🇵🇹 Português' : '🇬🇧 English';
const reviewsText = isEnglish ? 'Reviews' : 'Críticas';
const aboutText = isEnglish ? 'About' : 'Sobre';
---

<header class="kdp-header">
  <nav class="nav-container">
    <a href={homeLink} class="logo-link">
      <img src="/logo.svg" alt="One Thousand Works Logo" class="logo" />
    </a>
    
    <div class="nav-links">
      <HeaderLink href={homeLink}>Home</HeaderLink>
      <HeaderLink href={blogLink}>{reviewsText}</HeaderLink>
      <HeaderLink href={aboutLink}>{aboutText}</HeaderLink>
    </div>

    <div class="nav-actions">
      <a href={langToggleLink} class="lang-pill">
        <span>{langToggleText}</span>
      </a>
    </div>
  </nav>
</header>

<style>
  .kdp-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg-dark);
    border-bottom: 4px solid var(--accent);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
  }

  .nav-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
  }

  .logo-link {
    display: flex;
    align-items: center;
  }

  .logo {
    height: 42px;
    width: auto;
    filter: invert(1) brightness(2.5);
    transition: transform 0.3s ease;
  }

  .logo:hover {
    transform: scale(1.02);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-actions {
    display: flex;
    align-items: center;
  }

  .lang-pill {
    display: inline-flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #e0e0e0;
    padding: 0.4rem 0.95rem;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .lang-pill:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: #ffffff;
    transform: translateY(-1px);
    box-shadow: 0 4px 10px rgba(228, 121, 17, 0.2);
  }

  @media (max-width: 640px) {
    .nav-container {
      padding: 0.7rem 1rem;
    }
    
    .nav-links {
      gap: 1.2rem;
    }
    
    .logo {
      height: 34px;
    }
    
    .lang-pill {
      padding: 0.3rem 0.7rem;
      font-size: 0.8rem;
    }
  }
</style>
